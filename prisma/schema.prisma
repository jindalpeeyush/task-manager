generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String   @unique
  emailVerified DateTime?
  image         String?
  tasks         Task[]
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  priority    String
  status      String   @default("pending")
  deadline    DateTime?
  tags        String[]
  assignedTo  User?     @relation(fields: [assignedToId], references: [id])
  assignedToId String?
  createdAt   DateTime  @default(now())
}